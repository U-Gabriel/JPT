      "/notice/create": {
        "post": {
          "tags": [
            "Notice"
          ],
          "summary": "Création d'une remarque ou d'un feedback.",
          "description": "Permet à un utilisateur d'envoyer une remarque, liée ou non à un objet spécifique.",
