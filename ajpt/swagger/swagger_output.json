      "/tags": {
        "get": {
          "tags": [
            "Tag"
          ],
          "summary": "Récupère la liste de tous les tags.",
          "description": "Retourne l'ensemble des catégories disponibles pour les FAQ et les remarques.",
          "produces": [
            "application/json"
          ],
          "responses": {
            "200": {
              "description": "Liste des tags récupérée avec succès.",
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "example": "OK" },
                  "message": { "type": "string", "example": null },
                  "code": { "type": "integer", "example": 200 },
                  "data": {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/Tag"
                    }
                  }
                }
              }
            },
            "204": {
              "description": "Aucun tag trouvé."
            }
          },
          "security": [
            {
              "Bearer": []
            }
          ]
        }
      },
      "/faqs/tag": {
        "post": {
          "tags": ["FAQ"],
          "summary": "Récupère les FAQs (filtres tag et recherche textuelle).",
          "description": "Permet de filtrer par ID de tag et/ou par mot-clé dans la question.",
          "parameters": [
            {
              "name": "body",
              "in": "body",
              "required": false,
              "schema": {
                "type": "object",
                "properties": {
                  "id_tag": {
                    "type": "integer",
                    "example": 1
                  },
                  "title_search": {
                    "type": "string",
                    "example": "batterie",
                    "description": "Recherche un mot ou une phrase dans le titre de la question."
                  }
                }
              }
            }
          ],
          "responses": {
            "200": { "description": "Succès", "schema": { "$ref": "#/definitions/FaqListResponse" } }
          }
        }
      },
      "/faqs/object": {
        "post": {
          "tags": ["FAQ"],
          "summary": "Récupère les FAQs liées à un objet spécifique.",
          "description": "Cette route nécessite obligatoirement un id_object. Elle renvoie les questions spécifiques à ce matériel.",
          "parameters": [
            {
              "name": "body",
              "in": "body",
              "required": true,
              "schema": {
                "type": "object",
                "required": ["id_object"],
                "properties": {
                  "id_object": {
                    "type": "integer",
                    "example": 2,
                    "description": "ID de l'objet physique concerné."
                  }
                }
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Succès",
              "schema": { "$ref": "#/definitions/FaqListResponse" }
            },
            "401": { "description": "Paramètre id_object manquant." },
            "500": { "description": "Erreur serveur interne" }
          }
        }
      },
      "/shop/catalog": {
        "post": {
          "tags": ["Shopping Public"],
          "summary": "Récupère le catalogue des produits avec leurs images.",
          "description": "Retourne la liste des produits actifs. Chaque produit contient un tableau d'objets 'assets' regroupant ses photos.",
          "parameters": [
            {
              "name": "body",
              "in": "body",
              "required": false,
              "schema": {
                "type": "object",
                "properties": {
                  "id_tag": { 
                    "type": "integer", 
                    "example": 1,
                    "description": "Filtrer par catégorie" 
                  },
                  "title_search": { 
                    "type": "string", 
                    "example": "capteur",
                    "description": "Recherche dans le titre de l'objet"
                  }
                }
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Catalogue récupéré avec succès.",
              "schema": {
                "$ref": "#/definitions/CatalogResponse"
              }
            }
          }
        }
      },
      "/shop/catalog/details": {
        "post": {
          "tags": [
            "Shopping Public"
          ],
          "summary": "Récupérer les détails complets d'un produit spécifique",
          "description": "Retourne toutes les informations d'un objet (caractéristiques, prix, stock, garanties) ainsi que la liste de ses photos associées.",
          "produces": [
            "application/json"
          ],
          "parameters": [
            {
              "in": "body",
              "name": "body",
              "description": "Identifiant de l'objet à récupérer",
              "required": true,
              "schema": {
                "type": "object",
                "required": [
                  "id_object"
                ],
                "properties": {
                  "id_object": {
                    "type": "integer",
                    "example": 1,
                    "description": "L'ID unique de l'objet en base de données"
                  }
                }
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Détails du produit récupérés avec succès",
              "schema": {
