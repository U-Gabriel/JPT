      "/object_profile/resume/byperson": {
        "get": {
          "tags": [
            "Object Profile"
          ],
          "summary": "Résumé des profils d'objets par personne",
          "description": "Récupère la liste des objets activés appartenant à l'utilisateur connecté via son token (Bearer).",
          "produces": [
            "application/json"
          ],
          "responses": {
            "200": {
              "description": "Liste des profils d'objets récupérée avec succès",
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "example": "OK" },
                  "message": { "type": "string", "nullable": true, "example": null },
                  "code": { "type": "integer", "example": 200 },
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id_object_profile": { "type": "integer", "example": 2 },
                        "title": { "type": "string", "example": "Ma Plante Salon" },
                        "is_automatic": { "type": "boolean", "example": false },
                        "is_water": { "type": "boolean", "example": true },
                        "state": { "type": "integer", "example": 5 },
                        "plant_type": {
                          "type": "object",
                          "properties": {
                            "id_plant_type": { "type": "integer", "example": 1 },
                            "title": { "type": "string", "example": "Lavande" },
                            "path_picture": { "type": "string", "example": "dataset/plants/lavande_ref.png" },
                            "avatar": {
                              "type": "object",
                              "nullable": true,
                              "properties": {
                                "title": { "type": "string", "example": "Lavande Heureuse" },
                                "path_picture": { "type": "string", "example": "dataset/avatar/Lavande/Lavande5.png" }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "401": {
              "description": "Non autorisé - Token absent ou invalide"
            },
            "500": {
              "description": "Erreur interne du serveur"
            }
          },
          "security": [
            {
              "Bearer": []
            }
          ]
        }
      },
