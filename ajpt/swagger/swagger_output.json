                        "is_automatic": { "type": "boolean", "example": false },
                        "is_water": { "type": "boolean", "example": false },
                        "state": { "type": "integer", "example": 1 },
                        "path_picture": { "type": "string", "example": "uploads/ma_plante.jpg" },
                        "plant_type": {
                          "type": "object",
                          "properties": {
                            "id_plant_type": { "type": "integer", "example": 1 },
                            "title": { "type": "string", "example": "Lavande" },
                            "avatar": {
                              "type": "object",
                              "nullable": true,
